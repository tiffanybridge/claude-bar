<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- "mac-application" = unsigned distribution (right-click Open needed on first launch) -->
    <!-- Change to "developer-id" if you have an Apple Developer ID certificate -->
    <key>method</key>
    <string>mac-application</string>

    <key>signingStyle</key>
    <string>manual</string>
</dict>
</plist>
